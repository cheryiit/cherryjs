{
  "name": "cherryjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "test": "vitest run --config vitest.config.ts",
    "test:arch": "vitest run --config vitest.config.ts tests/",
    "test:unit": "vitest run --config vitest.config.ts convex/**/*.test.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "lint:deps": "depcruise convex app --config .dependency-cruiser.cjs",
    "lint:duplicates": "jscpd convex app",
    "lint:unused": "knip",
    "lint:all": "npm run lint:deps && npm run lint:duplicates && npm run lint:unused",
    "typecheck": "tsc --noEmit",
    "check": "npm run test:arch && npm run lint:deps && npm run typecheck"
  },
  "dependencies": {
    "@convex-dev/action-retrier": "^0.3.0",
    "@convex-dev/aggregate": "^0.2.0",
    "@convex-dev/better-auth": "^0.10.0",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/react-query": "^0.1.0",
    "@convex-dev/resend": "^0.1.2-beta.2",
    "@convex-dev/workflow": "^0.3.9",
    "@radix-ui/react-alert-dialog": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@tanstack/react-form": "^1.27.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.143.0",
    "@tanstack/react-start": "^1.143.0",
    "better-auth": "^1.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.17.1",
    "convex-helpers": "^0.1.73",
    "framer-motion": "^12.23.0",
    "hono": "^4.6.14",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "dependency-cruiser": "^17.3.10",
    "jscpd": "^4.0.8",
    "knip": "^6.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vinxi": "^0.5.1",
    "vite": "^6.0.7",
    "vite-tsconfig-paths": "^4.3.0",
    "vitest": "^2.1.8"
  }
}
