{
  "name": "cherryjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "vite preview",
    "convex:dev": "convex dev --typecheck=disable",
    "convex:deploy": "convex deploy",
    "deploy": "alchemy deploy",
    "deploy:destroy": "alchemy destroy",
    "test": "vitest run --config vitest.config.ts",
    "test:arch": "vitest run --config vitest.config.ts tests/",
    "test:unit": "vitest run --config vitest.config.ts convex/**/*.test.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "lint:deps": "depcruise convex app --config .dependency-cruiser.cjs",
    "lint:duplicates": "jscpd convex app",
    "lint:convex": "eslint convex --max-warnings=0",
    "lint:all": "npm run lint:deps && npm run lint:duplicates && npm run lint:convex",
    "typecheck": "tsc --noEmit",
    "check": "npm run test:arch && npm run lint:deps && npm run lint:duplicates && npm run lint:convex && npm run typecheck"
  },
  "dependencies": {
    "@convex-dev/action-retrier": "^0.3.0",
    "@convex-dev/aggregate": "^0.2.1",
    "@convex-dev/better-auth": "^0.11.4",
    "@convex-dev/polar": "^0.9.0",
    "@convex-dev/r2": "^0.9.1",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/react-query": "^0.1.0",
    "@convex-dev/resend": "^0.2.3",
    "@convex-dev/workflow": "^0.3.9",
    "@polar-sh/checkout": "^0.1.15",
    "@polar-sh/sdk": "^0.45.2",
    "@radix-ui/react-alert-dialog": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@tanstack/react-form": "^1.27.0",
    "@tanstack/react-pacer": "^0.21.1",
    "@tanstack/react-query": "^5.96.0",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.167.0",
    "@tanstack/react-store": "^0.9.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "better-auth": "1.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "convex-helpers": "^0.1.114",
    "framer-motion": "^12.23.0",
    "hono": "^4.6.14",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.1",
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "alchemy": "^0.90.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.2.0",
    "jscpd": "^4.0.8",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.0.7",
    "vite-tsconfig-paths": "^4.3.0",
    "vitest": "^2.1.8",
    "wrangler": "^3.95.0"
  }
}
