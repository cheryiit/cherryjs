# ── Convex PROD deployment ────────────────────────────────────────────────────
# Used as a reference for what should be set on the Convex prod deployment.
# Apply with: npx convex env set --from-file .env.prod --prod
# Inspect with: npx convex env list --prod

# DO NOT commit the actual .env.prod file. This is the template.
# These values are SACRED — they affect real users, real charges, real emails.

SITE_URL=https://your-domain.com
BETTER_AUTH_SECRET=                          # rotate independently of dev

POLAR_SERVER=production                       # NOT sandbox
POLAR_ACCESS_TOKEN=                          # Polar production token
POLAR_ORGANIZATION_ID=
POLAR_WEBHOOK_SECRET=whsec_prod_...

RESEND_API_KEY=re_prod_...
RESEND_TEST_MODE=false                       # delivers real emails

R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cherryjs-prod

SLACK_WEBHOOK_URL=                           # prod alerts channel
