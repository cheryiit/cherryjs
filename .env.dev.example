# ── Convex DEV deployment ─────────────────────────────────────────────────────
# Used as a reference for what should be set on the Convex dev deployment.
# Apply with: npx convex env set --from-file .env.dev
# Inspect with: npx convex env list

# DO NOT commit the actual .env.dev file. This is the template.

SITE_URL=http://localhost:3000
BETTER_AUTH_SECRET=                          # dev-only secret, separate from prod

POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=                          # Polar sandbox token
POLAR_ORGANIZATION_ID=
POLAR_WEBHOOK_SECRET=whsec_dev_...

RESEND_API_KEY=re_dev_...
RESEND_TEST_MODE=true                        # never deliver real emails in dev

R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cherryjs-dev

SLACK_WEBHOOK_URL=                           # dev Slack channel
