# ── Convex ────────────────────────────────────────────────────────────────────
# CONVEX_DEPLOYMENT is auto-set by `npx convex dev` to dev:<name>
# For prod, `npx convex deploy` uses prod:<name> automatically.
CONVEX_DEPLOYMENT=dev:your-deployment-name
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=http://localhost:3000

# ── Better-Auth ───────────────────────────────────────────────────────────────
SITE_URL=http://localhost:3000
BETTER_AUTH_SECRET=                          # generate with: openssl rand -base64 32

# ── Polar Payments (optional) ─────────────────────────────────────────────────
# Used by @convex-dev/polar (lib/polar.ts). Get the tokens from
# https://polar.sh > Settings > API. Configure your products in Polar's
# dashboard, then copy their IDs into POLAR_PRODUCT_*.
POLAR_ACCESS_TOKEN=
POLAR_ORGANIZATION_ID=
POLAR_SERVER=sandbox                          # sandbox | production
POLAR_WEBHOOK_SECRET=whsec_...
POLAR_PRODUCT_PRO=                            # product id for the "pro" tier
POLAR_PRODUCT_TEAM=                           # product id for the "team" tier

# ── Resend Email (optional) ───────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_TEST_MODE=true                         # true in dev, false in prod

# ── Cloudflare R2 Storage (optional) ──────────────────────────────────────────
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cherryjs

# ── Slack Notifications (optional) ────────────────────────────────────────────
SLACK_WEBHOOK_URL=
